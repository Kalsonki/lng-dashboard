# Database
DATABASE_URL=postgresql+asyncpg://lng_user:lng_password@localhost:5432/lng_dashboard
DATABASE_URL_SYNC=postgresql://lng_user:lng_password@localhost:5432/lng_dashboard

# EIA API (free, get at https://www.eia.gov/opendata/)
EIA_API_KEY=your_eia_api_key_here

# GIE AGSI+ (free with registration at https://agsi.gie.eu)
GIE_API_KEY=your_gie_api_key_here

# AISstream (free tier at https://aisstream.io)
AISSTREAM_API_KEY=your_aisstream_key_here

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Analytics service
PORT=8000
DEBUG=true

# MapTiler (free tier at https://maptiler.com) - optional, fallback to CartoCDN
NEXT_PUBLIC_MAPTILER_KEY=
